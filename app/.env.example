# 今晚吃什么 · 环境变量示例
# 用法：复制为 .env 并填写；或在启动前 export。不配 MODEL_API_KEY 时自动走 mock 模式（内置示例数据，前端全链路可跑）。
# adapter = 配置：换模型只改下面三个变量，代码不动。

# —— 阿里云百炼（DashScope）OpenAI 兼容接口（推荐，你有阿里云账号）——
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 通义千问（便宜、稳、国内可达）。想用 DeepSeek 就换成百炼上的 deepseek 模型名（需在百炼开通）。
MODEL=qwen-flash
MODEL_API_KEY=

# —— 或用 DeepSeek 官方接口 ——
# MODEL_BASE_URL=https://api.deepseek.com/v1
# MODEL=deepseek-chat
# MODEL_API_KEY=sk-xxxx

# 可选
# PORT=3000
# MODEL_TIMEOUT_MS=20000
# MOCK=1        # 强制 mock，即使配了 key
